services:
  db:
    image: postgres:15-alpine
    container_name: upcycle_db
    restart: always
    environment:
      POSTGRES_DB: upcycleconnect
      POSTGRES_USER: upcycle_user
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - db_data:/var/lib/postgresql/data
    networks:
      - backend
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U upcycle_user -d upcycleconnect
      interval: 10s
      timeout: 5s
      retries: 5

  api:
    build: ./backend
    container_name: upcycle_api
    restart: always
    environment:
      DB_HOST: db
      DB_PORT: 5432
      DB_USER: upcycle_user
      DB_PASSWORD: ${DB_PASSWORD}
      DB_NAME: upcycleconnect
      JWT_SECRET: ${JWT_SECRET}
    depends_on:
      db:
        condition: service_healthy
    networks:
      - backend
      - frontend
    expose:
      - 8080
  web:
    build: ./frontend
    container_name: upcycle_web
    restart: always
    networks:
      - frontend
    expose:
      - 80

  nginx:
    image: nginx:alpine
    container_name: upcycle_nginx
    restart: always
    ports:
      - 3000:80
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - api
      - web
    networks:
      - frontend

networks:
  backend:
  frontend:

volumes:
  db_data:
